# Archivo de configuración de entorno
# Copiar a .env y modificar según tus necesidades
# Nota: No subir a Git si contiene credenciales reales

# Servidor
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Almacenamiento
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# OCR
OCR_LANGUAGE=spa+eng
DPI=200

# Tesseract (descomentar y ajustar si está en ruta no estándar en Windows)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Límites
MAX_FILE_SIZE_MB=50
MAX_PAGES=0

# Características
ENABLE_SIMPLE_MODE=True
ENABLE_ADVANCED_MODE=True
ENABLE_IMAGE_THUMBNAILS=True

# Logging
LOG_LEVEL=INFO
